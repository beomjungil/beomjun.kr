---
import * as m from '@/paraglide/messages';
import { languageTag } from '@/paraglide/runtime';
import IndexButton from './IndexButton.astro';
import IndexButtonLink from './IndexButtonLink.astro';

const currentLocale = languageTag();

const alternativeLocale = currentLocale === 'ko' ? 'en' : 'ko';
---

<section class='py-24 md:py-32 lg:pt-44 lg:pb-32'>
  <div class='flex container px-2 w-full flex-col'>
    <div class='overflow-hidden'>
      <h1
        class='text-balance text-[max(min(6vw,7em),3em)] font-extrabold leading-[1em] delay-300 duration-1000 animate-in fade-in slide-in-from-bottom fill-mode-both'
      >
        <span>
          {m.fullName()}
        </span>

        <span class='opacity-50 text-[0.5em] inline-block ml-1'>
          {m.fullName({}, { languageTag: alternativeLocale })}
        </span>
      </h1>
    </div>
    <div class='overflow-hidden'>
      <p
        class='pt-2 opacity-80 md:text-md delay-1000 duration-1000 animate-in fade-in slide-in-from-bottom fill-mode-both'
        set:html={m.mainGreetingDescription()}
      />
    </div>
  </div>

  <div class='mt-8 flex justify-end'>
    <div
      class='lg:pl-2'
      style={{
        width:
          'calc(min(1200px,100vw) + calc((100vw - min(1200px,100vw)) / 2))',
      }}
    >
      <div class='h-0.5 w-full bg-foreground'></div>
    </div>
  </div>

  <div class='container px-2'>
    <div class='flex w-full md:gap-4 flex-col md:flex-row'>
      <div class='flex flex-col w-full md:max-w-[24rem]'>
        <IndexButton to='about'>
          {m.aboutMe()}
        </IndexButton>
        <IndexButton to='blog'>
          {m.blog()}
        </IndexButton>
        <IndexButton to='get-in-touch'>
          {m.getInTouch()}
        </IndexButton>
      </div>
      <div class='flex flex-col w-full md:max-w-[24rem]'>
        <IndexButtonLink to='https://www.linkedin.com/in/beomjungil'>
          LinkedIn
        </IndexButtonLink>
        <IndexButtonLink to='https://github.com/beomjungil'>
          GitHub
        </IndexButtonLink>
        <IndexButtonLink to='https://instagr.am/gil.beomjun'>
          Instagram
        </IndexButtonLink>
      </div>
    </div>
  </div>
</section>
